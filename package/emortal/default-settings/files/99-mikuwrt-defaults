#!/bin/sh

# === IPv6: SLAAC IP + DHCPv6 DNS (stateless) ===
uci -q batch <<-SETV6
	set dhcp.lan.ra='server'
	set dhcp.lan.dhcpv6='server'
	set dhcp.lan.ra_management='2'
	add_list dhcp.lan.dns='2001:4860:4860::8888'
	add_list dhcp.lan.dns='2001:4860:4860::8844'
	commit dhcp
SETV6

# === LuCI: auto-refresh homepage stats + DHCP leases ===
uci -q batch <<-SETREFRESH
	set luci.main.pollinterval='3'
	commit luci
SETREFRESH

exit 0
