# === 设备平台 (from VIKINGYFY IPQ807X-WIFI-YES) ===
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_xiaomi_ax3600-stock=y

# === 全局设置 (from VIKINGYFY GENERAL) ===
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_kmod-inet-diag=y
# === 我们的定制 ===
# 网络: 10.0.0.1 / DHCP from .2
# (通过 package/base-files 和 dnsmasq 已修改默认值，不用 config 设)
# USB 网络共享
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-option=y
CONFIG_PACKAGE_usb-modeswitch=y
# 基础插件
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-theme-argon=y
ßCONFIG_PACKAGE_luci-app-argon-config=y
CONFIG_PACKAGE_kmod-sched-cake=y
CONFIG_PACKAGE_irqbalance=y
# 你的插件
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-openclash=y
# 中文
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-opkg-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-firewall-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-opkg-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-argon-config-zh_Hans=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y
